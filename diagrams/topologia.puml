@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowThickness 1.2
skinparam ArrowColor #333333
skinparam RectangleBorderColor #333333
skinparam RectangleFontColor #111111
skinparam RectangleRoundCorner 12
skinparam wrapWidth 240
skinparam maxMessageSize 220

title Cloud Honeypot – WireGuard – SIEM (OCI ARM64 – Zero Trust)

cloud "INTERNET" as Internet
rectangle "Admin User\n(Laptop)" as Admin

rectangle "Oracle Cloud Infrastructure (OCI)\nAlways Free Tier – ARM64 (Ampere A1)\nVCN: 10.0.1.0/24 | Subnet: 10.0.1.0/24" as OCI {

  ' --- fila superior: 2 columnas
  together {
    rectangle "SENSOR (Public Instance)\nOracle Linux 9 (ARM64)\nPrivate IP: 10.0.1.37\nPublic IP: x.x.x.x\n\nExposed services:\n- 22/TCP  Cowrie (SSH honeypot)\n- 80/TCP  DVWA (Web honeypot)\n\nAdmin (real SSH):\n- 2222/TCP (VPN-only)\n\nTelemetry:\n- Wazuh Agent\n- Docker containers (Cowrie + DVWA)" as Sensor

    rectangle "WIREGUARD (Public Instance)\nUbuntu 24.04 (ARM64)\nPrivate IP: 10.0.1.40\nPublic IP: x.x.x.x\n\nVPN entry:\n- 51820/UDP\n\nRole:\n- Single admin entry point\n- Private access to Sensor & SIEM" as WG
  }

  ' --- fila inferior: SIEM centrado
  rectangle "SIEM (Private Instance – NO Public IP)\nUbuntu 24.04 (ARM64)\nPrivate IP: 10.0.1.38\n\nComponents:\n- Wazuh Manager\n- Wazuh Dashboard\n\nReceives logs:\n- 1514/TCP (Wazuh)\n\nSecurity:\n- Not exposed to Internet\n- Access only via VPN/private network" as SIEM

  ' Truco: “links invisibles” para forzar la colocación (mejora layout)
  Sensor -[hidden]-> SIEM
  WG     -[hidden]-> SIEM
}

' --- Flujos (flechas cortas y claras)
Internet --> Sensor : Attack traffic\n22/TCP (Cowrie)\n80/TCP (DVWA)
Internet --> WG     : VPN entry\n51820/UDP

Sensor --> SIEM : Log forwarding (private)\n1514/TCP

Admin --> WG    : WireGuard tunnel\n51820/UDP
WG --> Sensor   : Admin SSH (private)\n2222/TCP (VPN-only)
WG --> SIEM     : Dashboard access (private)\n(via VPN)

note right of Sensor
Hardening:
- Real SSH moved to 2222
- Honeypot uses 22
end note

note bottom of SIEM
Zero Trust:
- SIEM isolated from Internet
- Least privilege rules in OCI
end note

@enduml
